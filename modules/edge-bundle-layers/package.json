  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest"
  },
  "peerDependencies": {
    "@deck.gl/core": "~9.3.0",
    "@deck.gl/layers": "~9.3.0"
  },
  "devDependencies": {
    "@deck.gl/test-utils": "~9.3.0",
    "@probe.gl/test-utils": "^4.0.4"
  }
}
