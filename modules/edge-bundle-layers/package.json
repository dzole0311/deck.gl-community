{
  "name": "@deck.gl-community/edge-bundle-layers",
  "version": "9.3.2",
  "description": "Edge bundling layer pack for deck.gl",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "layers",
    "visualization",
    "gpu",
    "deck.gl",
    "edges",
    "bundling"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs",
